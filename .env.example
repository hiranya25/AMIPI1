# ---- Target site ----
SITE_BASE_URL=https://www.example.com
MAX_PAGES=200
CRAWL_DELAY_SECONDS=0.5
USE_PLAYWRIGHT_FOR_JS=false

# ---- NVIDIA Nemotron API ----
AI_API_KEY=your_nvidia_api_key_here
AI_API_BASE=https://integrate.api.nvidia.com/v1
AI_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# ---- Google PageSpeed Insights ----
PAGESPEED_API_KEY=your_pagespeed_api_key_here

# ---- External SEO Data (Optional for Backlinks/Traffic) ----
SEO_API_KEY=your_se_ranking_api_key_here

# ---- Email delivery ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=your_email@gmail.com
EMAIL_RECIPIENTS=your_email@gmail.com,another@example.com

# ---- Scheduler ----
# Cron: minute hour day month day_of_week  (default: every Monday 6:00 AM)
WEEKLY_CRON=35 11 * * WED
