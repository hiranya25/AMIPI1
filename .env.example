# ---- Target site ----
SITE_BASE_URL=https://www.example.com
MAX_PAGES=200
CRAWL_DELAY_SECONDS=0.5
USE_PLAYWRIGHT_FOR_JS=false
CHECK_OUTBOUND_LINKS=true
CHECK_OUTBOUND_LINKS_ON_MOBILE=false

# ---- NVIDIA Nemotron API ----
AI_API_KEY=your_nvidia_api_key_here
AI_API_BASE=https://integrate.api.nvidia.com/v1
AI_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# ---- Google PageSpeed Insights ----
PAGESPEED_API_KEY=your_pagespeed_api_key_here

# ---- External SEO Data (Optional for Backlinks/Traffic via DataForSEO REST API) ----
# Set SEO_API_KEY as login:password or as the Base64 Basic token from DataForSEO.
# You can also use DATAFORSEO_LOGIN + DATAFORSEO_PASSWORD instead.
SEO_API_KEY=your_dataforseo_login:your_dataforseo_password
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
DATAFORSEO_LOCATION_CODE=2840
DATAFORSEO_LANGUAGE_CODE=en

# ---- Email delivery ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TIMEOUT=120
# Use SMTP_USE_SSL=true for port 465. Use SMTP_USE_STARTTLS=true for port 587.
SMTP_USE_SSL=false
SMTP_USE_STARTTLS=true
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=your_email@gmail.com
EMAIL_RECIPIENTS=your_email@gmail.com,another@example.com

# ---- Scheduler ----
# Cron: minute hour day month day_of_week
WEEKLY_CRON=0 6 * * MON
WEEKLY_CRON_TIMEZONE=America/New_York

# ---- Playwright ----
# On many shared cPanel systems Chromium needs --no-sandbox to launch.
PLAYWRIGHT_CHROMIUM_ARGS=--no-sandbox
